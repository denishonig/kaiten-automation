# Kaiten API Configuration
KAITEN_API_URL=https://your-space.kaiten.ru/api/latest
KAITEN_API_TOKEN=your_api_token_here

# ID полей критериев (входные данные)
# Эти поля должны существовать в карточках Kaiten

# Числовые поля (оценки от 1 до 5)
FIELD_AKTUALNOST=field_id_aktualnost
FIELD_NOVIZNA=field_id_novizna
FIELD_OPYT_SPIKERA=field_id_opyt_spikera
FIELD_HARIZMA=field_id_harizma
FIELD_PRIMENIMOST=field_id_priminimost  # 1-Вдохновиться, 2-Без рецепта, 3-Фрагментарно, 4-Toolkit, 5-Под ключ
FIELD_MASSOVOST=field_id_massovost  # 1-Для профи, 2-Для своих, 3-Связующее звено, 4-Для всей команды, 5-Для всей IT-кухни

# Текстовое/Select поле
FIELD_INFLUENCER=field_id_influencer  # "Да"/"Нет" или True/False

# ID полей результатов (выходные данные)
# Эти поля будут автоматически обновляться скриптом
FIELD_RATING_KACHESTVA=field_id_rating_kachestva
FIELD_TIP_KONTENTA=field_id_tip_kontenta
FIELD_UROVEN_SPIKERA=field_id_uroven_spikera
FIELD_OHVAT=field_id_ohvat

# Опционально: ID доски или пространства для фильтрации карточек
# BOARD_ID=board_id_here
# SPACE_ID=space_id_here

# --- Сверка программы (python -m program_truth) ---
# Таблица: экспорт CSV (Файл → Опубликовать в веб или ссылка export?format=csv&gid=...)
# PROGRAM_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/<id>/export?format=csv&gid=0
# PROGRAM_SHEET_TITLE_COLUMN=Название
# PROGRAM_SHEET_URL_COLUMN=Ссылка

# Kaiten: несколько пространств, колонка доски «В программе»
# PROGRAM_KAITEN_SPACE_IDS=111,222
# PROGRAM_KAITEN_COLUMN_TITLE=В программе
# Явные id колонок (если авто-поиск по названию не подходит):
# PROGRAM_KAITEN_PROGRAM_COLUMN_IDS=

# Шаблон ссылки на карточку в UI ({card_id}, {board_id}, {space_id})
# KAITEN_CARD_URL_TEMPLATE=https://example.kaiten.ru/...

# Сайт: список докладов
# PROGRAM_SITE_URL=https://conf.example.org/schedule
# PROGRAM_SITE_ITEM_SELECTOR=article.talk
# PROGRAM_SITE_LINK_SELECTOR=a.talk-link
# PROGRAM_SITE_TITLE_SELECTOR=h3

# Опции: обрезка utm из URL (1), порог fuzzy 0–100 (0 = выкл.)
# PROGRAM_STRIP_UTM=1
# PROGRAM_FUZZY_THRESHOLD=0
